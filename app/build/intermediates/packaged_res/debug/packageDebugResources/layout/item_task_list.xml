<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="14dp" android:paddingVertical="14dp">

        <CheckBox android:id="@+id/cb_completed"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:buttonTint="@color/orange_primary" android:layout_marginEnd="12dp"/>

        <ImageView android:id="@+id/iv_icon"
            android:layout_width="22dp" android:layout_height="22dp"
            android:src="@drawable/ic_brain" android:layout_marginEnd="12dp"
            android:importantForAccessibility="no"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tv_title"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Task" android:textColor="@color/text_primary"
                    android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                <TextView android:id="@+id/tv_featured"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text=" ★" android:textColor="@color/orange_primary"
                    android:textSize="12sp" android:visibility="gone"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="2dp">
                <TextView android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="subtitle" android:textColor="@color/text_hint"
                    android:textSize="12sp"/>
                <!-- Streak chip -->
                <TextView android:id="@+id/tv_streak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="🔥 5 days" android:textColor="@color/streak_gold"
                    android:textSize="11sp" android:fontFamily="sans-serif-medium"
                    android:background="@drawable/streak_badge_bg"
                    android:paddingHorizontal="6dp" android:paddingVertical="2dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <ImageButton android:id="@+id/btn_edit"
            android:layout_width="34dp" android:layout_height="34dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_hint" android:contentDescription="Edit"/>
        <ImageButton android:id="@+id/btn_delete"
            android:layout_width="34dp" android:layout_height="34dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/error_red" android:contentDescription="Delete"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
