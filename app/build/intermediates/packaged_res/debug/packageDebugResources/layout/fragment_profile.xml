<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp"
        android:paddingTop="48dp" android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="28dp">
            <View android:layout_width="4dp" android:layout_height="28dp"
                android:background="@color/orange_primary" android:layout_marginEnd="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PROFILE" android:textColor="@color/text_primary"
                android:textSize="22sp" android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Avatar + date -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:orientation="vertical" android:layout_marginBottom="28dp">
            <androidx.cardview.widget.CardView android:layout_width="88dp" android:layout_height="88dp"
                app:cardCornerRadius="44dp" app:cardBackgroundColor="@color/bg_card"
                android:layout_marginBottom="12dp">
                <ImageView android:layout_width="match_parent" android:layout_height="match_parent"
                    android:src="@drawable/ic_profile_large" android:padding="20dp"
                    android:importantForAccessibility="no"/>
            </androidx.cardview.widget.CardView>
            <TextView android:id="@+id/tv_today_date"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2025-01-01" android:textColor="@color/text_hint" android:textSize="13sp"
                android:background="@drawable/streak_badge_bg"
                android:paddingHorizontal="12dp" android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- Stats -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="28dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="8dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="18dp">
                    <TextView android:id="@+id/tv_completed_today"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/orange_primary"
                        android:textSize="28sp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TODAY" android:textColor="@color/text_hint"
                        android:textSize="10sp" android:letterSpacing="0.1"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="8dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="18dp">
                    <TextView android:id="@+id/tv_total_tasks"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/text_primary"
                        android:textSize="28sp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TOTAL" android:textColor="@color/text_hint"
                        android:textSize="10sp" android:letterSpacing="0.1"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Name field -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="YOUR NAME" android:textColor="@color/text_hint"
            android:textSize="11sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:boxBackgroundColor="@color/bg_card" app:boxBackgroundMode="filled"
            app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp"
            app:hintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_name"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/text_primary" android:hint="Sir"
                android:inputType="textPersonName" android:padding="14dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="SAVE CHANGES" android:textColor="@color/text_primary"
            android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/orange_primary" app:cornerRadius="14dp"/>
    </LinearLayout>
</ScrollView>
