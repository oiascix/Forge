<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp"
        android:paddingTop="48dp" android:paddingBottom="24dp">

        <!-- Logo -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="28dp">
            <View android:layout_width="4dp" android:layout_height="36dp"
                android:background="@color/orange_primary" android:layout_marginEnd="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="FORGE" android:textColor="@color/text_primary"
                android:textSize="22sp" android:letterSpacing="0.12" android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Greeting -->
        <TextView android:id="@+id/tv_greeting" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Good Morning, Sir"
            android:textColor="@color/text_primary" android:textSize="26sp"
            android:fontFamily="sans-serif-medium" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tv_time" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Time: 00:00"
            android:textColor="@color/text_secondary" android:textSize="14sp"/>
        <TextView android:id="@+id/tv_subtitle" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Time to work"
            android:textColor="@color/text_secondary" android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- Day Progress -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="TODAY'S PROGRESS"
                        android:textColor="@color/text_hint" android:textSize="11sp" android:letterSpacing="0.12"/>
                    <TextView android:id="@+id/tv_day_progress" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 / 0 done today"
                        android:textColor="@color/orange_secondary" android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
                <ProgressBar android:id="@+id/progress_day"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="10dp"
                    android:max="100" android:progress="0"
                    android:progressDrawable="@drawable/progress_day"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Core Heat -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="CORE HEAT"
                android:textColor="@color/text_hint" android:textSize="11sp" android:letterSpacing="0.15"/>
            <TextView android:id="@+id/tv_heat_value" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="1500°"
                android:textColor="@color/orange_primary" android:textSize="13sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_project_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Forging: Titanium Blade (two days left)"
            android:textColor="@color/text_primary" android:textSize="13sp" android:layout_marginBottom="10dp"/>
        <ProgressBar android:id="@+id/progress_heat"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:max="100" android:progress="75"
            android:progressDrawable="@drawable/progress_heat" android:layout_marginBottom="24dp"/>

        <!-- Daily Protocol label -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DAILY PROTOCOL" android:textColor="@color/text_hint"
            android:textSize="11sp" android:letterSpacing="0.15" android:layout_marginBottom="12dp"/>

        <!-- Featured card -->
        <include android:id="@+id/card_featured" layout="@layout/item_task_featured"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Grid -->
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_tasks"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</ScrollView>
